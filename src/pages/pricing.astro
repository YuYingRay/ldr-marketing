---
import PageLayout from "@/layouts/PageLayout.astro";
import PricingTable from "@/components/PricingTable.astro";
import CTABanner from "@/components/CTABanner.astro";
---

<PageLayout
  title="Pricing — LDR Lighting Design Rendering"
  description="Simple pricing for AI-powered nightscape rendering. Start free with 1 render per day, upgrade to Pro for 4K output and unlimited segmentations."
>
  <section class="max-w-6xl mx-auto px-4 py-20">
    <PricingTable />
  </section>

  <section class="max-w-4xl mx-auto px-4 pb-20">
    <h2 class="text-2xl font-bold text-center mb-8">Frequently Asked Questions</h2>
    <div class="space-y-6">
      <div>
        <h3 class="font-semibold mb-2">Can I try LDR for free?</h3>
        <p class="text-muted-foreground text-sm">Yes. Every account gets 1 free render per day at 1K resolution. No credit card required.</p>
      </div>
      <div>
        <h3 class="font-semibold mb-2">What resolution are the renders?</h3>
        <p class="text-muted-foreground text-sm">Free plan renders at 1K resolution. Pro and Max plans render at up to 4K (4096px) resolution, suitable for professional presentations and publications.</p>
      </div>
      <div>
        <h3 class="font-semibold mb-2">Can I cancel my subscription?</h3>
        <p class="text-muted-foreground text-sm">Yes, you can cancel anytime. Your subscription remains active until the end of the current billing period.</p>
      </div>
      <div>
        <h3 class="font-semibold mb-2">What image formats are supported?</h3>
        <p class="text-muted-foreground text-sm">We accept JPG, PNG, and WebP images up to 20MB. The AI works best with clear daytime architectural or landscape photos.</p>
      </div>
    </div>
  </section>

  <CTABanner />
</PageLayout>
