---
import { getCollection, render } from "astro:content";
import PageLayout from "@/layouts/PageLayout.astro";
import type { Lang } from "@/i18n/ui";
import { useTranslations } from "@/i18n/utils";

const lang: Lang = "zh";
const t = useTranslations(lang);

export async function getStaticPaths() {
  let posts: Awaited<ReturnType<typeof getCollection<"blog">>> = [];
  try {
    posts = await getCollection("blog-zh" as "blog");
  } catch {
    // Collection not yet defined — no static paths generated
  }
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const { title, description, pubDate, author, image } = post.data;

const formattedDate = pubDate.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description,
  datePublished: pubDate.toISOString(),
  author: {
    "@type": "Organization",
    name: "LDR 团队",
  },
  publisher: {
    "@type": "Organization",
    name: "LDR - 灯光设计渲染",
    url: "https://www.ldr-design.com",
  },
  ...(image ? { image: image.url } : {}),
};
---

<PageLayout
  title={`${title} — LDR 博客`}
  description={description}
  ogImage={image?.url}
  jsonLd={jsonLd}
  lang={lang}
>
  <article class="max-w-3xl mx-auto px-4 pt-20 pb-24">
    <a
      href="/zh/blog"
      class="inline-flex items-center gap-2 text-sm text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))] transition-colors mb-10"
    >
      {t("blog.backToBlog")}
    </a>

    {
      image && (
        <div class="aspect-video overflow-hidden rounded-2xl mb-10">
          <img
            src={image.url}
            alt={image.alt}
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
      )
    }

    <header class="mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-[hsl(var(--foreground))] leading-tight">
        {title}
      </h1>
      <div
        class="mt-4 flex items-center gap-4 text-sm text-[hsl(var(--muted-foreground))]"
      >
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span aria-hidden="true">&bull;</span>
        <span>{author}</span>
      </div>
    </header>

    <div
      class="prose prose-neutral dark:prose-invert max-w-none
             prose-headings:font-bold prose-headings:text-[hsl(var(--foreground))]
             prose-p:text-[hsl(var(--muted-foreground))] prose-p:leading-relaxed
             prose-a:text-[hsl(var(--primary))] prose-a:no-underline hover:prose-a:underline
             prose-strong:text-[hsl(var(--foreground))]
             prose-li:text-[hsl(var(--muted-foreground))]
             prose-table:text-sm prose-th:text-[hsl(var(--foreground))]
             prose-td:text-[hsl(var(--muted-foreground))]
             prose-code:text-[hsl(var(--foreground))] prose-code:bg-[hsl(var(--muted)/0.4)]
             prose-code:px-1 prose-code:py-0.5 prose-code:rounded"
    >
      <Content />
    </div>

    <footer class="mt-16 pt-8 border-t border-[hsl(var(--border))]">
      <a
        href="/zh/blog"
        class="text-sm text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))] transition-colors"
      >
        {t("blog.backToBlog")}
      </a>
    </footer>
  </article>
</PageLayout>
