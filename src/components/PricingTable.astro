---
const APP_URL = "https://app.ldr-design.com";

interface Plan {
  name: string;
  price: string;
  period: string;
  tagline: string;
  features: string[];
  cta: string;
  ctaHref: string;
  popular?: boolean;
  ctaVariant: "primary" | "outline";
}

// Section 1 — Trial & Subscriptions (Free + Mini + Pro + Max)
const plansSection: Plan[] = [
  {
    name: "Free",
    price: "$0",
    period: "forever",
    tagline: "Try before you buy",
    features: [
      "5 credits on signup",
      "1 free generation per day",
      "1K resolution with watermark",
      "All features available (Canvas + Chat)",
    ],
    cta: "Get Started",
    ctaHref: APP_URL,
    ctaVariant: "outline",
  },
  {
    name: "Mini",
    price: "$9",
    period: "one-time",
    tagline: "First paid tier — try commercial quality",
    features: [
      "5 credits (~2-3 4K commercial images)",
      "4K resolution, no watermark",
      "All features unlocked",
      "Valid for 15 days",
    ],
    cta: "Buy Mini",
    ctaHref: `${APP_URL}/pricing`,
    ctaVariant: "primary",
  },
  {
    name: "Pro",
    price: "$99",
    period: "month",
    tagline: "Steady flow — 2-3 projects per month",
    features: [
      "120 credits / month (~60 4K images)",
      "Batch generation (5 parallel)",
      "Priority generation queue",
      "4K no watermark · full feature set",
      "Cancel anytime, no next-cycle charge",
    ],
    cta: "Subscribe to Pro",
    ctaHref: `${APP_URL}/pricing`,
    popular: true,
    ctaVariant: "primary",
  },
  {
    name: "Max",
    price: "$249",
    period: "month",
    tagline: "Teams — 10+ projects per month",
    features: [
      "400 credits / month (~200 4K images)",
      "Batch + priority queue",
      "API access",
      "Priority email support",
      "Cancel anytime, no next-cycle charge",
    ],
    cta: "Subscribe to Max",
    ctaHref: `${APP_URL}/pricing`,
    ctaVariant: "primary",
  },
];

// Section 2 — Project Packs (Small + Standard + Large, all one-time)
const packsSection: Plan[] = [
  {
    name: "Small",
    price: "$59",
    period: "one-time",
    tagline: "One small project, 5-10 images",
    features: [
      "30 credits (~15 4K images)",
      "4K no watermark",
      "Canvas editor + Chat Agent",
      "Valid for 30 days",
    ],
    cta: "Buy Small",
    ctaHref: `${APP_URL}/pricing`,
    ctaVariant: "outline",
  },
  {
    name: "Standard",
    price: "$129",
    period: "one-time",
    tagline: "Fits a 14-image commercial project",
    features: [
      "80 credits (~40 4K images)",
      "Canvas iterative refinement",
      "All features + Channel diagram",
      "Valid for 90 days",
    ],
    cta: "Buy Standard",
    ctaHref: `${APP_URL}/pricing`,
    popular: true,
    ctaVariant: "primary",
  },
  {
    name: "Large",
    price: "$299",
    period: "one-time",
    tagline: "Multi-round iteration or 50+ images",
    features: [
      "250 credits (~125 4K images)",
      "Canvas + Chat + Channel diagram",
      "Priority support response",
      "Valid for 180 days",
    ],
    cta: "Buy Large",
    ctaHref: `${APP_URL}/pricing`,
    ctaVariant: "outline",
  },
];
---

<section class="py-20 px-4">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[hsl(var(--foreground))]">
      Simple, Transparent Pricing
    </h2>
    <p class="mt-3 text-center text-[hsl(var(--muted-foreground))]">
      Pay per project or subscribe for steady flow · Global USD pricing · Alipay / WeChat Pay / Cards supported
    </p>

    {/* Section 1: Trial & Subscriptions */}
    <div class="mt-16">
      <div class="text-center mb-8">
        <h3 class="text-xl font-semibold text-[hsl(var(--foreground))]">Trial & Subscriptions</h3>
        <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
          From free trial to monthly subscriptions · upgrade anytime
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          plansSection.map((plan) => (
            <div
              class={[
                "relative bg-[hsl(var(--card))] border rounded-2xl p-6 flex flex-col gap-6 h-full",
                plan.popular
                  ? "border-[hsl(var(--primary))] shadow-lg"
                  : "border-[hsl(var(--border))]",
              ].join(" ")}
            >
              {plan.popular && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                  <span class="bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap">
                    Most Popular
                  </span>
                </div>
              )}

              <div>
                <h4 class="text-lg font-semibold text-[hsl(var(--foreground))]">
                  {plan.name}
                </h4>
                <div class="mt-2 flex items-baseline gap-1">
                  <span class="text-4xl font-bold text-[hsl(var(--foreground))]">
                    {plan.price}
                  </span>
                  <span class="text-sm text-[hsl(var(--muted-foreground))]">
                    /{plan.period}
                  </span>
                </div>
                <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
                  {plan.tagline}
                </p>
              </div>

              <ul class="flex flex-col gap-3 flex-1">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm text-[hsl(var(--foreground))]">
                    <svg
                      class="w-4 h-4 mt-0.5 shrink-0 text-emerald-500"
                      viewBox="0 0 16 16"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path
                        d="M13.5 4.5L6.5 11.5L3 8"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>

              <a
                href={plan.ctaHref}
                class={[
                  "inline-flex items-center justify-center px-5 py-2.5 rounded-xl text-sm font-semibold transition-opacity",
                  plan.ctaVariant === "primary"
                    ? "bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] hover:opacity-90"
                    : "border border-[hsl(var(--border))] text-[hsl(var(--foreground))] hover:bg-[hsl(var(--muted))]",
                ].join(" ")}
              >
                {plan.cta}
              </a>
            </div>
          ))
        }
      </div>
    </div>

    {/* Section 2: Project Packs */}
    <div class="mt-20">
      <div class="text-center mb-8">
        <h3 class="text-xl font-semibold text-[hsl(var(--foreground))]">Project Packs</h3>
        <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
          Buy by project · no subscription · use credits flexibly within validity
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {
          packsSection.map((plan) => (
            <div
              class={[
                "relative bg-[hsl(var(--card))] border rounded-2xl p-6 flex flex-col gap-6 h-full",
                plan.popular
                  ? "border-[hsl(var(--primary))] shadow-lg"
                  : "border-[hsl(var(--border))]",
              ].join(" ")}
            >
              {plan.popular && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                  <span class="bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap">
                    Most Popular
                  </span>
                </div>
              )}

              <div>
                <h4 class="text-lg font-semibold text-[hsl(var(--foreground))]">
                  {plan.name}
                </h4>
                <div class="mt-2 flex items-baseline gap-1">
                  <span class="text-4xl font-bold text-[hsl(var(--foreground))]">
                    {plan.price}
                  </span>
                  <span class="text-sm text-[hsl(var(--muted-foreground))]">
                    /{plan.period}
                  </span>
                </div>
                <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
                  {plan.tagline}
                </p>
              </div>

              <ul class="flex flex-col gap-3 flex-1">
                {plan.features.map((feature) => (
                  <li class="flex items-start gap-2 text-sm text-[hsl(var(--foreground))]">
                    <svg
                      class="w-4 h-4 mt-0.5 shrink-0 text-emerald-500"
                      viewBox="0 0 16 16"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path
                        d="M13.5 4.5L6.5 11.5L3 8"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    {feature}
                  </li>
                ))}
              </ul>

              <a
                href={plan.ctaHref}
                class={[
                  "inline-flex items-center justify-center px-5 py-2.5 rounded-xl text-sm font-semibold transition-opacity",
                  plan.ctaVariant === "primary"
                    ? "bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] hover:opacity-90"
                    : "border border-[hsl(var(--border))] text-[hsl(var(--foreground))] hover:bg-[hsl(var(--muted))]",
                ].join(" ")}
              >
                {plan.cta}
              </a>
            </div>
          ))
        }
      </div>
    </div>

    <p class="mt-12 text-center text-xs text-[hsl(var(--muted-foreground))] max-w-2xl mx-auto">
      Packs are non-refundable (credits available within validity). Subscriptions can be canceled anytime with no current-period refund.
    </p>
  </div>
</section>
