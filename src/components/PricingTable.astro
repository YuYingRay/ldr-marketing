---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);

const APP_URL = "https://app.ldr-design.com";

type PlanKey = "free" | "mini" | "pro" | "max" | "small" | "standard" | "large";
type PeriodKey = "forever" | "oneTime" | "month";

interface Plan {
  planKey: PlanKey;
  price: string;
  periodKey: PeriodKey;
  featureCount: number;
  ctaHref: string;
  popular?: boolean;
  ctaVariant: "primary" | "outline";
}

// Section 1 — Trial & Subscriptions (Free + Mini + Pro + Max)
const plansSection: Plan[] = [
  {
    planKey: "free",
    price: "$0",
    periodKey: "forever",
    featureCount: 4,
    ctaHref: APP_URL,
    ctaVariant: "outline",
  },
  {
    planKey: "mini",
    price: "$9",
    periodKey: "oneTime",
    featureCount: 4,
    ctaHref: `${APP_URL}/pricing`,
    ctaVariant: "primary",
  },
  {
    planKey: "pro",
    price: "$99",
    periodKey: "month",
    featureCount: 5,
    ctaHref: `${APP_URL}/pricing`,
    popular: true,
    ctaVariant: "primary",
  },
  {
    planKey: "max",
    price: "$249",
    periodKey: "month",
    featureCount: 5,
    ctaHref: `${APP_URL}/pricing`,
    ctaVariant: "primary",
  },
];

// Section 2 — Project Packs (Small + Standard + Large, all one-time)
const packsSection: Plan[] = [
  {
    planKey: "small",
    price: "$59",
    periodKey: "oneTime",
    featureCount: 4,
    ctaHref: `${APP_URL}/pricing`,
    ctaVariant: "outline",
  },
  {
    planKey: "standard",
    price: "$129",
    periodKey: "oneTime",
    featureCount: 4,
    ctaHref: `${APP_URL}/pricing`,
    popular: true,
    ctaVariant: "primary",
  },
  {
    planKey: "large",
    price: "$299",
    periodKey: "oneTime",
    featureCount: 4,
    ctaHref: `${APP_URL}/pricing`,
    ctaVariant: "outline",
  },
];
---

<section class="py-20 px-4">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[hsl(var(--foreground))]">
      {t("pricing.heading")}
    </h2>
    <p class="mt-3 text-center text-[hsl(var(--muted-foreground))]">
      {t("pricing.subtitle")}
    </p>

    {/* Section 1: Trial & Subscriptions */}
    <div class="mt-16">
      <div class="text-center mb-8">
        <h3 class="text-xl font-semibold text-[hsl(var(--foreground))]">{t("pricing.subSection")}</h3>
        <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
          {t("pricing.subSectionDesc")}
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {
          plansSection.map((plan) => {
            const rmb = lang === "zh" ? t(`pricing.${plan.planKey}.rmb`) : "";
            return (
            <div
              class={[
                "relative bg-[hsl(var(--card))] border rounded-2xl p-6 flex flex-col gap-6 h-full",
                plan.popular
                  ? "border-[hsl(var(--primary))] shadow-lg"
                  : "border-[hsl(var(--border))]",
              ].join(" ")}
            >
              {plan.popular && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                  <span class="bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap">
                    {t("pricing.popular")}
                  </span>
                </div>
              )}

              <div>
                <h4 class="text-lg font-semibold text-[hsl(var(--foreground))]">
                  {t(`pricing.${plan.planKey}.name`)}
                </h4>
                <div class="mt-2 flex items-baseline gap-1">
                  <span class="text-4xl font-bold text-[hsl(var(--foreground))]">
                    {plan.price}
                  </span>
                  <span class="text-sm text-[hsl(var(--muted-foreground))]">
                    /{t(`pricing.period.${plan.periodKey}`)}
                  </span>
                </div>
                {rmb && (
                  <p class="mt-1 text-xs text-[hsl(var(--muted-foreground))]">{rmb}</p>
                )}
                <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
                  {t(`pricing.${plan.planKey}.tagline`)}
                </p>
              </div>

              <ul class="flex flex-col gap-3 flex-1">
                {Array.from({ length: plan.featureCount }, (_, i) => i + 1).map((n) => (
                  <li class="flex items-start gap-2 text-sm text-[hsl(var(--foreground))]">
                    <svg
                      class="w-4 h-4 mt-0.5 shrink-0 text-emerald-500"
                      viewBox="0 0 16 16"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path
                        d="M13.5 4.5L6.5 11.5L3 8"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    {t(`pricing.${plan.planKey}.f${n}`)}
                  </li>
                ))}
              </ul>

              <a
                href={plan.ctaHref}
                class={[
                  "inline-flex items-center justify-center px-5 py-2.5 rounded-xl text-sm font-semibold transition-opacity",
                  plan.ctaVariant === "primary"
                    ? "bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] hover:opacity-90"
                    : "border border-[hsl(var(--border))] text-[hsl(var(--foreground))] hover:bg-[hsl(var(--muted))]",
                ].join(" ")}
              >
                {t(`pricing.${plan.planKey}.cta`)}
              </a>
            </div>
          )})
        }
      </div>
    </div>

    {/* Section 2: Project Packs */}
    <div class="mt-20">
      <div class="text-center mb-8">
        <h3 class="text-xl font-semibold text-[hsl(var(--foreground))]">{t("pricing.packSection")}</h3>
        <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
          {t("pricing.packSectionDesc")}
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {
          packsSection.map((plan) => {
            const rmb = lang === "zh" ? t(`pricing.${plan.planKey}.rmb`) : "";
            return (
            <div
              class={[
                "relative bg-[hsl(var(--card))] border rounded-2xl p-6 flex flex-col gap-6 h-full",
                plan.popular
                  ? "border-[hsl(var(--primary))] shadow-lg"
                  : "border-[hsl(var(--border))]",
              ].join(" ")}
            >
              {plan.popular && (
                <div class="absolute -top-3 left-1/2 -translate-x-1/2">
                  <span class="bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] text-xs font-semibold px-3 py-1 rounded-full whitespace-nowrap">
                    {t("pricing.popular")}
                  </span>
                </div>
              )}

              <div>
                <h4 class="text-lg font-semibold text-[hsl(var(--foreground))]">
                  {t(`pricing.${plan.planKey}.name`)}
                </h4>
                <div class="mt-2 flex items-baseline gap-1">
                  <span class="text-4xl font-bold text-[hsl(var(--foreground))]">
                    {plan.price}
                  </span>
                  <span class="text-sm text-[hsl(var(--muted-foreground))]">
                    /{t(`pricing.period.${plan.periodKey}`)}
                  </span>
                </div>
                {rmb && (
                  <p class="mt-1 text-xs text-[hsl(var(--muted-foreground))]">{rmb}</p>
                )}
                <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
                  {t(`pricing.${plan.planKey}.tagline`)}
                </p>
              </div>

              <ul class="flex flex-col gap-3 flex-1">
                {Array.from({ length: plan.featureCount }, (_, i) => i + 1).map((n) => (
                  <li class="flex items-start gap-2 text-sm text-[hsl(var(--foreground))]">
                    <svg
                      class="w-4 h-4 mt-0.5 shrink-0 text-emerald-500"
                      viewBox="0 0 16 16"
                      fill="none"
                      xmlns="http://www.w3.org/2000/svg"
                      aria-hidden="true"
                    >
                      <path
                        d="M13.5 4.5L6.5 11.5L3 8"
                        stroke="currentColor"
                        stroke-width="1.75"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                    {t(`pricing.${plan.planKey}.f${n}`)}
                  </li>
                ))}
              </ul>

              <a
                href={plan.ctaHref}
                class={[
                  "inline-flex items-center justify-center px-5 py-2.5 rounded-xl text-sm font-semibold transition-opacity",
                  plan.ctaVariant === "primary"
                    ? "bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] hover:opacity-90"
                    : "border border-[hsl(var(--border))] text-[hsl(var(--foreground))] hover:bg-[hsl(var(--muted))]",
                ].join(" ")}
              >
                {t(`pricing.${plan.planKey}.cta`)}
              </a>
            </div>
          )})
        }
      </div>
    </div>

    <p class="mt-12 text-center text-xs text-[hsl(var(--muted-foreground))] max-w-2xl mx-auto">
      {t("pricing.disclaimer")}
    </p>
  </div>
</section>
