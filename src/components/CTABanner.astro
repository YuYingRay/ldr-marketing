---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const APP_URL = "https://app.ldr-design.com";
---

<section class="py-20 px-4">
  <div class="max-w-2xl mx-auto flex flex-col items-center text-center">
    <h2 class="text-3xl font-bold text-[hsl(var(--foreground))]">
      {t("cta.heading")}
    </h2>

    <p class="mt-4 text-[hsl(var(--muted-foreground))]">
      {t("cta.subtitle")}
    </p>

    <a
      href={APP_URL}
      class="mt-8 inline-flex items-center justify-center px-8 py-3 text-lg font-semibold rounded-xl bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] hover:opacity-90 transition-opacity"
    >
      {t("cta.button")}
    </a>

    <p class="mt-4 text-sm text-[hsl(var(--muted-foreground))]">
      {t("cta.note")}
    </p>
  </div>
</section>
