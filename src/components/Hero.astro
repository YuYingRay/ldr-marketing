---
interface Props {
  showcase?: {
    day_image_url: string;
    night_image_url: string;
    prompt: string;
    category: string;
  };
}

const APP_URL = "https://app.ldr-design.com";
const { showcase } = Astro.props;
---

<section class="flex flex-col items-center justify-center text-center py-20 md:py-32 px-4">
  <h1 class="text-4xl md:text-6xl font-bold tracking-tight max-w-4xl">
    Transform Daylight Photos into Professional Nightscape Renderings
  </h1>

  <p class="mt-6 text-lg text-[hsl(var(--muted-foreground))] max-w-2xl">
    AI-powered lighting design visualization. Upload a daytime photo, get a professional
    nightscape rendering in seconds.
  </p>

  <div class="mt-10 flex flex-col sm:flex-row items-center gap-4">
    <a
      href={APP_URL}
      class="inline-flex items-center justify-center px-6 py-3 rounded-xl text-base font-semibold bg-[hsl(var(--primary))] text-[hsl(var(--primary-foreground))] hover:opacity-90 transition-opacity"
    >
      Start Rendering Free
    </a>
    <a
      href="#showcase"
      class="inline-flex items-center justify-center px-6 py-3 rounded-xl text-base font-semibold border border-[hsl(var(--border))] text-[hsl(var(--foreground))] hover:bg-[hsl(var(--muted))] transition-colors"
    >
      See Examples
    </a>
  </div>

  {showcase ? (
    <div class="mt-16 w-full max-w-5xl rounded-2xl border border-[hsl(var(--border))] overflow-hidden relative" data-compare>
      <div class="relative aspect-video">
        <!-- Day image (left / background) -->
        <img
          src={showcase.day_image_url}
          alt={`Daytime photo of ${showcase.category} — ${showcase.prompt}`}
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
        />
        <!-- Night image (right / clipped) -->
        <div class="absolute inset-0 overflow-hidden" id="compare-overlay" style="clip-path: inset(0 0 0 50%);">
          <img
            src={showcase.night_image_url}
            alt={`AI nightscape rendering of ${showcase.category} — ${showcase.prompt}`}
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
          />
        </div>
        <!-- Slider line -->
        <div class="absolute top-0 bottom-0 w-px bg-white/60 z-20 pointer-events-none" id="compare-line" style="left: 50%;">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 bg-white/90 rounded-full flex items-center justify-center shadow-lg">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M5 3L2 8L5 13" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M11 3L14 8L11 13" stroke="#333" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
        <!-- Labels -->
        <span class="absolute top-3 left-3 text-xs text-white/80 bg-black/50 px-2 py-1 rounded-full z-10">Day</span>
        <span class="absolute top-3 right-3 text-xs text-white/80 bg-black/50 px-2 py-1 rounded-full z-10">Night</span>
      </div>
    </div>
  ) : (
    <div class="mt-16 w-full max-w-5xl aspect-video bg-[hsl(var(--card))] border border-[hsl(var(--border))] rounded-2xl flex flex-col items-center justify-center gap-4">
      <p class="text-[hsl(var(--muted-foreground))] text-lg">See before/after examples below</p>
      <a href="#showcase" class="text-sm underline text-[hsl(var(--muted-foreground))] hover:text-[hsl(var(--foreground))]">
        Scroll to gallery
      </a>
    </div>
  )}
</section>

<script>
  const container = document.querySelector("[data-compare]");
  if (container) {
    const overlay = document.getElementById("compare-overlay");
    const line = document.getElementById("compare-line");
    let dragging = false;

    function update(clientX: number) {
      const rect = container!.getBoundingClientRect();
      const pct = Math.max(0, Math.min(100, ((clientX - rect.left) / rect.width) * 100));
      overlay!.style.clipPath = `inset(0 0 0 ${pct}%)`;
      line!.style.left = `${pct}%`;
    }

    container.addEventListener("mousedown", (e) => { dragging = true; update((e as MouseEvent).clientX); });
    container.addEventListener("mousemove", (e) => { if (dragging) update((e as MouseEvent).clientX); });
    document.addEventListener("mouseup", () => { dragging = false; });
    container.addEventListener("touchstart", (e) => { dragging = true; update((e as TouchEvent).touches[0].clientX); }, { passive: true });
    container.addEventListener("touchmove", (e) => { if (dragging) update((e as TouchEvent).touches[0].clientX); }, { passive: true });
    document.addEventListener("touchend", () => { dragging = false; });

    container.classList.add("cursor-ew-resize", "select-none");
  }
</script>
