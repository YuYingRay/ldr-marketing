---
const steps = [
  {
    number: "01",
    title: "Upload",
    description:
      "Upload a daytime photo of any building, landscape, or urban scene",
  },
  {
    number: "02",
    title: "Describe",
    description:
      "Tell the AI your lighting vision, or let it suggest the perfect design",
  },
  {
    number: "03",
    title: "Render",
    description:
      "Get your professional nightscape rendering in under 60 seconds",
  },
];
---

<section class="py-20 px-4 bg-[hsl(var(--muted)/0.3)]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[hsl(var(--foreground))]">
      How It Works
    </h2>

    <div class="mt-12 grid md:grid-cols-3 gap-8">
      {
        steps.map((step) => (
          <div class="flex flex-col items-center text-center">
            <span class="text-4xl font-bold text-[hsl(var(--primary)/0.2)] select-none">
              {step.number}
            </span>
            <h3 class="mt-4 text-lg font-semibold text-[hsl(var(--foreground))]">
              {step.title}
            </h3>
            <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
