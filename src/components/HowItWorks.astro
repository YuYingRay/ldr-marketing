---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);

const steps = [
  { number: "01", title: t("how.step1.title"), description: t("how.step1.desc") },
  { number: "02", title: t("how.step2.title"), description: t("how.step2.desc") },
  { number: "03", title: t("how.step3.title"), description: t("how.step3.desc") },
];
---

<section class="py-20 px-4 bg-[hsl(var(--muted)/0.3)]">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[hsl(var(--foreground))]">
      {t("how.heading")}
    </h2>

    <div class="mt-12 grid md:grid-cols-3 gap-8">
      {
        steps.map((step) => (
          <div class="flex flex-col items-center text-center">
            <span class="text-4xl font-bold text-[hsl(var(--primary)/0.2)] select-none">
              {step.number}
            </span>
            <h3 class="mt-4 text-lg font-semibold text-[hsl(var(--foreground))]">
              {step.title}
            </h3>
            <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
