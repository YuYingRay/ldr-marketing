---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Showcase {
  id: string;
  prompt: string;
  prompt_zh?: string;
  category: string;
  day_image_url: string;
  night_image_url: string;
}

interface Props {
  showcases?: Showcase[];
  lang?: Lang;
}

const { showcases = [], lang = "en" } = Astro.props;
const t = useTranslations(lang);
const hasItems = showcases.length > 0;

const categoryZh: Record<string, string> = {
  Architecture: "建筑",
  Commercial: "商业",
  Landscape: "景观",
  Urban: "城市",
  Hospitality: "酒店",
  Residential: "住宅",
  Cultural: "文化",
  Industrial: "工业",
  Sports: "体育",
  Public: "公共",
  Park: "公园",
  Bridge: "桥梁",
  Road: "道路",
  Plaza: "广场",
  Waterfront: "滨水",
};

function localCategory(cat: string) {
  return lang === "zh" ? categoryZh[cat] ?? cat : cat;
}

function localPrompt(item: Showcase) {
  return lang === "zh" && item.prompt_zh ? item.prompt_zh : item.prompt;
}
---

<section id="showcase" class="py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[hsl(var(--foreground))]">
      {t("showcase.heading")}
    </h2>

    <div class="mt-12 grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        hasItems ? (
          showcases.map((item) => (
            <div class="surface-card bg-[hsl(var(--card))] border border-[hsl(var(--border))] rounded-2xl overflow-hidden">
              <div class="aspect-[4/3] relative">
                <img
                  src={item.night_image_url}
                  alt={`${localCategory(item.category)} — ${localPrompt(item)}`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                  decoding="async"
                />
                <span class="absolute top-3 left-3 text-xs bg-[hsl(var(--background)/0.9)] text-[hsl(var(--foreground))] px-2 py-1 rounded-full">
                  {localCategory(item.category)}
                </span>
              </div>
              <div class="p-4">
                <p class="text-sm text-[hsl(var(--muted-foreground))] line-clamp-2">
                  {localPrompt(item)}
                </p>
              </div>
            </div>
          ))
        ) : (
          <div class="md:col-span-2 lg:col-span-3 surface-card bg-[hsl(var(--card))] border border-[hsl(var(--border))] rounded-2xl overflow-hidden">
            <div class="aspect-[4/3] relative flex items-center justify-center bg-[hsl(var(--muted)/0.4)]">
              <span class="text-[hsl(var(--muted-foreground))] text-sm">
                {t("showcase.empty")}
              </span>
            </div>
            <div class="p-4">
              <p class="text-sm text-[hsl(var(--muted-foreground))] line-clamp-2">
                {t("showcase.emptyDesc")}
              </p>
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>
