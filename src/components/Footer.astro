---
import type { Lang } from "../i18n/ui";
import { useTranslations, getLocalizedPath } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
const appUrl = "https://app.ldr-design.com";

const navLinks = [
  { label: t("footer.useCases"), href: getLocalizedPath("/use-cases", lang) },
  { label: t("footer.pricing"), href: getLocalizedPath("/pricing", lang) },
  { label: t("footer.blog"), href: getLocalizedPath("/blog", lang) },
  { label: t("footer.app"), href: appUrl, external: true },
];

const legalLinks = [
  { label: t("footer.terms"), href: "/terms" },
  { label: t("footer.privacy"), href: "/privacy" },
  { label: t("footer.refund"), href: "/refund" },
];
---

<footer class="border-t border-border py-5 text-xs text-muted-foreground">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-3">
      <!-- Left: brand + copyright -->
      <p class="flex items-center gap-2">
        <a
          href={getLocalizedPath("/", lang)}
          class="font-bold text-foreground hover:text-primary transition-colors"
        >
          LDR
        </a>
        <span aria-hidden="true" class="text-border">&middot;</span>
        <span>{t("footer.copyright")}</span>
      </p>

      <!-- Right: nav links + legal links, single row -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap items-center gap-x-5 gap-y-2">
          {navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target={link.external ? "_blank" : undefined}
                rel={link.external ? "noopener noreferrer" : undefined}
                class="hover:text-foreground transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
          <li aria-hidden="true" class="text-border">&middot;</li>
          {legalLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="hover:text-foreground transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</footer>
