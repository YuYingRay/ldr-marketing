---
const features = [
  {
    icon: "⚡",
    title: "Day to Night in Seconds",
    description:
      "Upload any daytime architectural or landscape photo and get a professional nightscape rendering instantly.",
  },
  {
    icon: "🤖",
    title: "AI-Powered Precision",
    description:
      "Our AI understands architectural context, material properties, and light physics for realistic results.",
  },
  {
    icon: "🔍",
    title: "Semantic Segmentation",
    description:
      "Intelligent scene understanding with HQ-SAM technology separates buildings, sky, vegetation automatically.",
  },
  {
    icon: "🖼",
    title: "4K Professional Output",
    description:
      "Publication-ready renders at up to 4096px resolution. No watermark on Pro plans.",
  },
];
---

<section class="py-20 px-4">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[hsl(var(--foreground))]">
      Why LDR?
    </h2>

    <div class="mt-12 grid md:grid-cols-2 gap-6">
      {
        features.map((feature) => (
          <div class="surface-card p-6 rounded-2xl border border-[hsl(var(--border))] bg-[hsl(var(--card))]">
            <div class="w-10 h-10 rounded-lg bg-[hsl(var(--primary)/0.1)] text-[hsl(var(--primary))] flex items-center justify-center text-xl">
              {feature.icon}
            </div>
            <h3 class="mt-4 text-lg font-semibold text-[hsl(var(--foreground))]">
              {feature.title}
            </h3>
            <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
