---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);

const features = [
  { icon: "⚡", title: t("features.speed.title"), description: t("features.speed.desc") },
  { icon: "🤖", title: t("features.ai.title"), description: t("features.ai.desc") },
  { icon: "🔍", title: t("features.seg.title"), description: t("features.seg.desc") },
  { icon: "🖼", title: t("features.quality.title"), description: t("features.quality.desc") },
];
---

<section class="py-20 px-4">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[hsl(var(--foreground))]">
      {t("features.heading")}
    </h2>

    <div class="mt-12 grid md:grid-cols-2 gap-6">
      {
        features.map((feature) => (
          <div class="surface-card p-6 rounded-2xl border border-[hsl(var(--border))] bg-[hsl(var(--card))]">
            <div class="w-10 h-10 rounded-lg bg-[hsl(var(--primary)/0.1)] text-[hsl(var(--primary))] flex items-center justify-center text-xl">
              {feature.icon}
            </div>
            <h3 class="mt-4 text-lg font-semibold text-[hsl(var(--foreground))]">
              {feature.title}
            </h3>
            <p class="mt-2 text-sm text-[hsl(var(--muted-foreground))]">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
